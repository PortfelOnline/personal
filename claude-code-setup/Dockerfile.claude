FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates openssh-client \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

RUN useradd -m claude
ENV HOME=/home/claude
USER claude
WORKDIR /workspace

ENTRYPOINT ["claude"]
