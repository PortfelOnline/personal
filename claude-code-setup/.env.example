# Required
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Optional: Groq API key for vision (image description fallback)
GROQ_API_KEY=gsk_your-groq-key-here

# Optional: OCR language (rus+eng for bilingual docs)
OCR=rus+eng

# Optional: Override for Claude API key (routes claude models to native API)
ANTHROPIC_AUTH_TOKEN=
